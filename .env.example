# Pro API key, issued from https://agent-ready.dev/dashboard/api-keys.
# Required for `scan`, `get`, and `list`. Not needed for `ask`.
AGENT_READY_API_KEY=ar_live_xxx

# Override the API base URL (default: https://agent-ready.dev). Useful for local dev.
# AGENT_READY_API_URL=http://localhost:3000

# Optional timeout overrides (milliseconds).
# AGENT_READY_SCAN_TIMEOUT_MS=120000
# AGENT_READY_GET_TIMEOUT_MS=10000
